<launch>
  <!-- SocketCAN interface -->
  <arg name="interface" default="can1" />
  <arg name="receiver_interval_sec" default="0.01" />
  <arg name="launch_driver" default="true" />

  <!-- Launch SocketCAN receiver (shared by both radars)
       from_can_bus_topic must match the remap in both radar nodes below -->
  <include file="$(find-pkg-share ros2_socketcan)/launch/socket_can_receiver.launch.py"
           if="$(var launch_driver)">
    <arg name="interface" value="$(var interface)" />
    <arg name="interval_sec" value="$(var receiver_interval_sec)" />
    <arg name="from_can_bus_topic" value="/sensing/radar/can_tx" />
  </include>

  <!-- Radar FRONT (SensorID=0) -->
  <node pkg="pe_ars408_ros" exec="pe_ars408_node"
        name="pe_ars408_node_front"
        namespace="radar_front"
        output="screen">
    <param from="$(find-pkg-share pe_ars408_ros)/config/radar_front.yaml" />
    <remap from="~/input/frame" to="/sensing/radar/can_tx" />
  </node>

  <!-- Radar REAR (SensorID=1) -->
  <node pkg="pe_ars408_ros" exec="pe_ars408_node"
        name="pe_ars408_node_rear"
        namespace="radar_rear"
        output="screen">
    <param from="$(find-pkg-share pe_ars408_ros)/config/radar_rear.yaml" />
    <remap from="~/input/frame" to="/sensing/radar/can_tx" />
  </node>

</launch>
